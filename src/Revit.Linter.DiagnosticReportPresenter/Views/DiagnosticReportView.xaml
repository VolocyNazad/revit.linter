<UserControl
    x:Class="Revit.Linter.DiagnosticReportPresenter.Views.DiagnosticReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Revit.Linter.DiagnosticReportPresenter.Infrasructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:infrastructure="clr-namespace:Revit.Linter.DiagnosticReportPresenter.Infrasructure"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Revit.Linter.DiagnosticReportPresenter.ViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type viewModels:DiagnosticReportViewModel}}"
    d:DesignHeight="450"
    d:DesignWidth="1400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Cyan"
                    SecondaryColor="DeepOrange" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:DebugConverter x:Key="DebugConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding InitializeCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <materialDesign:ColorZone
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch">
        <DockPanel>
            <DockPanel Height="50" DockPanel.Dock="Top">
                <ToggleButton
                    Width="35"
                    Height="35"
                    Margin="10,5,5,5"
                    materialDesign:ToggleButtonAssist.OnContent="{materialDesign:PackIcon Kind=Pause,
                                                                                          Size=30}"
                    Background="Transparent"
                    Content="{materialDesign:PackIcon Kind=Play,
                                                      Size=30}"
                    DockPanel.Dock="Left"
                    Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                    IsChecked="True"
                    IsEnabled="false"
                    Style="{StaticResource MaterialDesignActionToggleButton}" />
                <Button
                    Width="35"
                    Height="35"
                    Margin="5"
                    d:Command="{x:Null}"
                    Command="{Binding RunDiagnosticCommand}"
                    Content="{materialDesign:PackIcon Kind=Play,
                                                      Size=30}"
                    DockPanel.Dock="Left"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="{Binding DiagnosticTime}" />
                <Rectangle
                    Width="1"
                    Margin="0,5"
                    VerticalAlignment="Stretch"
                    DockPanel.Dock="Left"
                    Fill="{DynamicResource MaterialDesignDivider}" />
                <ListBox
                    VerticalAlignment="Center"
                    DataContext="{Binding SeverityFilters}"
                    DockPanel.Dock="Left"
                    ItemsSource="{Binding}"
                    Style="{StaticResource MaterialDesignFilterChipSecondaryListBox}">
                    <ListBox.ItemContainerStyle>
                        <Style BasedOn="{StaticResource MaterialDesignFilterChipSecondaryListBoxItem}" TargetType="{x:Type ListBoxItem}">
                            <Setter Property="IsSelected" Value="{Binding IsActive, Mode=TwoWay}" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                <ListBox
                    VerticalAlignment="Center"
                    d:ItemsSource="{d:SampleData ItemCount=3}"
                    DataContext="{Binding Filters}"
                    DockPanel.Dock="Left"
                    ItemsSource="{Binding}"
                    Style="{StaticResource MaterialDesignFilterChipSecondaryListBox}">
                    <ListBox.ItemContainerStyle>
                        <Style BasedOn="{StaticResource MaterialDesignFilterChipSecondaryListBoxItem}" TargetType="{x:Type ListBoxItem}">
                            <Setter Property="IsSelected" Value="{Binding IsActive, Mode=TwoWay}" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                <Rectangle
                    Width="1"
                    Margin="0,5"
                    VerticalAlignment="Stretch"
                    DockPanel.Dock="Left"
                    Fill="{DynamicResource MaterialDesignDivider}" />
                <CheckBox
                    Margin="10,0,10,0"
                    Content="On active view"
                    DockPanel.Dock="Left"
                    IsChecked="{Binding OnActiveViewMode}" />
                <Rectangle
                    Width="1"
                    Margin="0,5"
                    VerticalAlignment="Stretch"
                    DockPanel.Dock="Left"
                    Fill="{DynamicResource MaterialDesignDivider}" />
                <Button
                    Content="{materialDesign:PackIcon Kind=FilterPlus,
                                                      Size=20}"
                    DockPanel.Dock="Right"
                    IsEnabled="False"
                    Style="{StaticResource MaterialDesignIconButton}" />
                <TextBox
                    Width="200"
                    Margin="5"
                    materialDesign:HintAssist.Hint="Search"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Search"
                    DockPanel.Dock="Right"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Text="{Binding SearchField, UpdateSourceTrigger=LostFocus}" />
                <TextBlock
                    Margin="5"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    Text="Reports:" />
                <UIElement />
            </DockPanel>
            <Rectangle
                Height="1"
                HorizontalAlignment="Stretch"
                DockPanel.Dock="Top"
                Fill="{DynamicResource MaterialDesignDivider}" />
            <DataGrid
                d:ItemsSource="{d:SampleData ItemCount=2}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                ItemsSource="{Binding CollectionViewSource.View}">
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource MaterialDesignDataGridRow}" TargetType="DataGridRow">
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" ItemsSource="{Binding Fixes}">
                                    <ContextMenu.ItemContainerStyle>
                                        <Style BasedOn="{StaticResource MaterialDesignMenuItem}" TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding Title}" />
                                            <Setter Property="Command" Value="{Binding FixCommand}" />
                                            <Setter Property="Icon" Value="{Binding Icon}"/>
                                        </Style>
                                    </ContextMenu.ItemContainerStyle>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Resources>
                    <infrastructure:BindingProxy x:Key="proxy" DataContext="{Binding}" />
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DataTemplate.Resources>
                                    <Style x:Key="HasFixesPackIconStyle" TargetType="{x:Type materialDesign:PackIcon}">
                                        <Setter Property="Foreground" Value="#FFB74D" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Fixes}" Value="{x:Null}">
                                                <Setter Property="Foreground" Value="Transparent" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataTemplate.Resources>
                                <materialDesign:PackIcon
                                    Width="12"
                                    Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="Idea"
                                    Style="{StaticResource HasFixesPackIconStyle}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    Width="25"
                                    Height="25"
                                    Content="{materialDesign:PackIcon Kind=Refresh,
                                                                      Size=20}"
                                    IsEnabled="False"
                                    Style="{StaticResource MaterialDesignIconButton}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Severity" SortMemberPath="Severity">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <DataTemplate.Resources>
                                    <Style
                                        x:Key="SeverityChipStyle"
                                        BasedOn="{StaticResource MaterialDesignOutlineChip}"
                                        TargetType="{x:Type materialDesign:Chip}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                <Setter Property="BorderBrush" Value="#FFB74D" />
                                                <Setter Property="Foreground" Value="#FFB74D" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                <Setter Property="BorderBrush" Value="#EF5350" />
                                                <Setter Property="Foreground" Value="#EF5350" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataTemplate.Resources>
                                <materialDesign:Chip
                                    Margin="0"
                                    d:Content="Severity"
                                    Content="{Binding Severity}"
                                    Style="{StaticResource SeverityChipStyle}">
                                    <materialDesign:Chip.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding Severity}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </materialDesign:Chip.ContextMenu>
                                </materialDesign:Chip>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Code" SortMemberPath="Code">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center">
                                    <Run d:Text="Code" Text="{Binding Code}" />
                                    <TextBlock.Style>
                                        <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsObsolete}" Value="True">
                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                    <Setter Property="ToolTip" Value="{Binding ObsoleteDescription}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding Code}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Message" SortMemberPath="Message">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <FlowDocumentScrollViewer
                                    Width="1300"
                                    Document="{Binding Message}"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Disabled">
                                    <FlowDocumentScrollViewer.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding Message}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </FlowDocumentScrollViewer.ContextMenu>
                                </FlowDocumentScrollViewer>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Document" SortMemberPath="DocumentTitle">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding DocumentTitle}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                    <Run Text="{Binding DocumentTitle}" />
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </materialDesign:ColorZone>
</UserControl>
