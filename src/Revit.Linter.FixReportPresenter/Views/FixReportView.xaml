<UserControl
    x:Class="Revit.Linter.FixReportPresenter.Views.FixReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:infrastructure="clr-namespace:Revit.Linter.FixReportPresenter.Infrasructure"
    xmlns:local="clr-namespace:Revit.Linter.FixReportPresenter.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Revit.Linter.FixReportPresenter.ViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type viewModels:FixReportViewModel}}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Cyan"
                    SecondaryColor="DeepOrange" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <viewModels:ServiceLocator x:Key="ServiceLocator" />
        </ResourceDictionary>
    </UserControl.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding InitializeCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <materialDesign:ColorZone
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch">
        <DockPanel>
            <DockPanel Height="50" DockPanel.Dock="Top">
                <ContentControl Content="{Binding RunDiagnosticView, Source={StaticResource ServiceLocator}}" />
                <ComboBox
                    MinWidth="150"
                    Margin="5"
                    materialDesign:HintAssist.Hint="Document"
                    DisplayMemberPath="DisplayName"
                    ItemsSource="{Binding OpenedDocumentsViewModel.Collection, Source={StaticResource ServiceLocator}}"
                    SelectedValue="{Binding TargetDocumentTitle}"
                    SelectedValuePath="Title"
                    Style="{StaticResource MaterialDesignComboBox}" />
                <Button
                    Content="{materialDesign:PackIcon Kind=FilterPlus,
                                                      Size=20}"
                    DockPanel.Dock="Right"
                    IsEnabled="False"
                    Style="{StaticResource MaterialDesignIconButton}" />
                <TextBox
                    Width="200"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    materialDesign:HintAssist.Hint="Search"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Search"
                    DockPanel.Dock="Right"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Text="{Binding SearchField, UpdateSourceTrigger=LostFocus}" />
                <TextBlock
                    Margin="5"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    Text="Fixes:" />
                <UIElement />
            </DockPanel>
            <Rectangle
                Height="1"
                HorizontalAlignment="Stretch"
                DockPanel.Dock="Top"
                Fill="{DynamicResource MaterialDesignDivider}" />
            <DataGrid
                d:ItemsSource="{d:SampleData ItemCount=2}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                ItemsSource="{Binding CollectionViewSource.View}">
                <DataGrid.Resources>
                    <infrastructure:BindingProxy x:Key="proxy" DataContext="{Binding}" />
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Code" SortMemberPath="Code">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center">
                                    <Run d:Text="Code" Text="{Binding Code}" />
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding Code}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Message" SortMemberPath="Message">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <FlowDocumentScrollViewer
                                    Width="1800"
                                    Document="{Binding Message}"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Disabled">
                                    <FlowDocumentScrollViewer.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding Message}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </FlowDocumentScrollViewer.ContextMenu>
                                </FlowDocumentScrollViewer>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Document" SortMemberPath="DocumentTitle">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding DocumentTitle}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                    <Run Text="{Binding DocumentTitle}" />
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Created" SortMemberPath="Created">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center">
                <Run d:Text="Created" Text="{Binding Created}" />
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                            Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                            CommandParameter="{Binding Created}"
                            Header="Copy"
                            Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </materialDesign:ColorZone>
</UserControl>
