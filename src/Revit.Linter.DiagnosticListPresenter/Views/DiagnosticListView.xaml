<UserControl
    x:Class="Revit.Linter.DiagnosticListPresenter.Views.DiagnosticListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:Revit.Linter.Core.Abstractions.Models;assembly=Revit.Linter.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:infrastructure="clr-namespace:Revit.Linter.DiagnosticListPresenter.Infrasructure"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:viewModels="clr-namespace:Revit.Linter.DiagnosticListPresenter.ViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type viewModels:DiagnosticListViewModel}}"
    d:DesignHeight="450"
    d:DesignWidth="600"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Cyan"
                    SecondaryColor="DeepOrange" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <ObjectDataProvider
                x:Key="DiagnosticSeverities"
                MethodName="GetValues"
                ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="core:DiagnosticSeverity" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </UserControl.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding InitializeCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <materialDesign:ColorZone
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch">
        <DockPanel Grid.Column="1">
            <DockPanel Height="50" DockPanel.Dock="Top">
                <Button
                    Content="{materialDesign:PackIcon Kind=FilterPlus,
                                                      Size=20}"
                    DockPanel.Dock="Right"
                    IsEnabled="False"
                    Style="{StaticResource MaterialDesignIconButton}" />
                <TextBox
                    Width="200"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    materialDesign:HintAssist.Hint="Search"
                    materialDesign:TextFieldAssist.HasLeadingIcon="True"
                    materialDesign:TextFieldAssist.LeadingIcon="Search"
                    DockPanel.Dock="Right"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Text="{Binding SearchField, UpdateSourceTrigger=LostFocus}" />
                <TextBlock
                    Margin="5"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    Text="Diagnostics:" />
                <UIElement />
            </DockPanel>
            <Rectangle
                Height="1"
                HorizontalAlignment="Stretch"
                DockPanel.Dock="Top"
                Fill="{DynamicResource MaterialDesignDivider}" />
            <DataGrid
                d:ItemsSource="{d:SampleData ItemCount=2}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                ItemsSource="{Binding CollectionViewSource.View}">
                <DataGrid.Resources>
                    <infrastructure:BindingProxy x:Key="proxy" DataContext="{Binding}" />
                </DataGrid.Resources>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem
                            Command="{Binding CheckAllCommand}"
                            Header="Check all"
                            Icon="{materialDesign:PackIcon Kind=CheckboxMultipleOutline}" />
                        <MenuItem
                            Command="{Binding UncheckAllCommand}"
                            Header="Uncheck all"
                            Icon="{materialDesign:PackIcon Kind=CheckboxMultipleBlankOutline}" />
                        <Separator />
                        <MenuItem Command="{Binding CheckVisibleCommand}" Header="Check visible" />
                        <MenuItem Command="{Binding UncheckVisibleCommand}" Header="Uncheck visible" />
                        <Separator />
                        <MenuItem
                            Command="{Binding InvertAllCommand}"
                            Header="Invert all"
                            Icon="{materialDesign:PackIcon Kind=SwapHorizontal}" />
                        <MenuItem Command="{Binding InvertVisibleCommand}" Header="Invert visible" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Margin="5,10,5,2"
                                    Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                    Text="{Binding Name}" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </DataGrid.GroupStyle>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn
                        Binding="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Header="IsActive"
                        SortMemberPath="IsActive" />
                    <DataGridTemplateColumn Header="Code" SortMemberPath="Code">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Code}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsObsolete}" Value="True">
                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                    <Setter Property="ToolTip" Value="{Binding ObsoleteDescription}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding Code}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Severity" SortMemberPath="Severity">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding Source={StaticResource DiagnosticSeverities}}" SelectedItem="{Binding Severity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding Severity}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </ComboBox.ContextMenu>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn
                        Width="*"
                        Header="Description"
                        SortMemberPath="Description">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Description}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsObsolete}" Value="True">
                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                    <Setter Property="ToolTip" Value="{Binding ObsoleteDescription}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding DataContext.CopyToClipboardCommand, Source={StaticResource proxy}}"
                                                CommandParameter="{Binding Description}"
                                                Header="Copy"
                                                Icon="{materialDesign:PackIcon Kind=ContentCopy}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </materialDesign:ColorZone>
</UserControl>
