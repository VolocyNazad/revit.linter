<UserControl
    x:Class="Revit.Linter.RunDiagnosticPresenter.Views.RunDiagnosticView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Revit.Linter.RunDiagnosticPresenter.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Revit.Linter.RunDiagnosticPresenter.ViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type viewModels:RunDiagnosticViewModel}}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Cyan"
                    SecondaryColor="DeepOrange" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding InitializeCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <DockPanel>
        <ToggleButton
            Width="35"
            Height="35"
            Margin="10,5,5,5"
            materialDesign:ToggleButtonAssist.OnContent="{materialDesign:PackIcon Kind=Pause,
                                                                                  Size=30}"
            Background="Transparent"
            Content="{materialDesign:PackIcon Kind=Play,
                                              Size=30}"
            DockPanel.Dock="Left"
            Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
            IsChecked="True"
            IsEnabled="false"
            Style="{StaticResource MaterialDesignActionToggleButton}" />
        <Button
            Width="35"
            Height="35"
            Margin="5"
            d:Command="{x:Null}"
            Command="{Binding RunDiagnosticCommand}"
            Content="{materialDesign:PackIcon Kind=Play,
                                              Size=30}"
            DockPanel.Dock="Left"
            Style="{StaticResource MaterialDesignIconButton}"
            ToolTip="{Binding DiagnosticTime}" />
        <Rectangle
            Width="1"
            Margin="0,5"
            VerticalAlignment="Stretch"
            DockPanel.Dock="Left"
            Fill="{DynamicResource MaterialDesignDivider}" />
        <CheckBox
            Margin="10,0,10,0"
            Content="On active view"
            DockPanel.Dock="Left"
            IsChecked="{Binding OnActiveViewMode}" />
    </DockPanel>
</UserControl>
